FROM python:3.11-slim AS base
ENV PYTHONDONTWRITEBYTECODE=1 PYTHONUNBUFFERED=1 PIP_NO_CACHE_DIR=1
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential gcc && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY valgo-common/ ./valgo-common/
RUN pip install --no-cache-dir -e ./valgo-common

COPY valgo-execution-router/ ./valgo-execution-router/
RUN pip install --no-cache-dir -e ./valgo-execution-router

WORKDIR /app/valgo-execution-router

RUN useradd -m -u 1000 valgo && chown -R valgo:valgo /app
USER valgo

EXPOSE 8090
CMD ["uvicorn", "execution_router.main:app", "--host", "0.0.0.0", "--port", "8090", "--workers", "2"]
