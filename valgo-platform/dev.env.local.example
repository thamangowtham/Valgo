# Single env file for local development. Loaded by docker-compose for every service.

ENV=local
LOG_LEVEL=INFO
AWS_REGION=ap-south-1

# These services are containerized in docker-compose; they reach each other by
# service name, not localhost.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

DYNAMODB_ENDPOINT=http://dynamodb-local:8000
DYNAMODB_TABLE_PREFIX=valgo_local_

# Kite Connect — get these from https://kite.trade/connect/
KITE_API_KEY=
KITE_API_SECRET=
# Generate via: docker compose run --rm auth-refresh-cli
KITE_ACCESS_TOKEN=

# TradingView webhook secret
TRADINGVIEW_SHARED_SECRET=local-dev-secret

# Internal service URLs (docker network)
EXECUTION_ROUTER_URL=http://execution-router:8090
DECISION_ENGINE_URL=http://decision:8091

ADMIN_API_PORT=8080
ADMIN_API_TOKEN=local-dev-token

# Operator alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
