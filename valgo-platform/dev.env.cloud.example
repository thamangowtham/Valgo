# Cloud / production reference env. Real deployments inject these via the
# ECS task definition; this file is the contract for what every service expects.

ENV=prod
LOG_LEVEL=WARNING
AWS_REGION=ap-south-1

# Managed services
REDIS_HOST=valgo-cache.<account>.cache.amazonaws.com
REDIS_PORT=6379

# Real DynamoDB endpoint = unset
DYNAMODB_ENDPOINT=
DYNAMODB_TABLE_PREFIX=valgo_prod_

# All secrets are SM secret IDs — looked up at process start.
KITE_API_KEY_SECRET_ID=valgo/kite/api_key
KITE_API_SECRET_SECRET_ID=valgo/kite/api_secret
KITE_ACCESS_TOKEN_SECRET_ID=valgo/kite/access_token
TRADINGVIEW_SHARED_SECRET_SECRET_ID=valgo/webhook/tradingview_secret
ADMIN_API_TOKEN_SECRET_ID=valgo/admin/api_token
TELEGRAM_BOT_TOKEN_SECRET_ID=valgo/telegram/bot_token

# Internal service hostnames (service-discovery / Cloud Map)
EXECUTION_ROUTER_URL=http://execution-router.valgo.internal:8090
DECISION_ENGINE_URL=http://decision.valgo.internal:8091

ADMIN_API_PORT=8080
TELEGRAM_CHAT_ID=
